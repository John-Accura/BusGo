# Postgres connection string (Neon etc.). Leave unset locally to use the
# embedded PGlite database in .data/pglite (auto-created and seeded).
DATABASE_URL=

# Secret for signing session JWTs. REQUIRED in production.
AUTH_SECRET=

# Platform admin login (auto-created on any database).
ADMIN_EMAIL=admin@busgo.local
ADMIN_PASSWORD=admin@123

# Demo data seeds automatically in development. In production it is skipped
# unless SEED_DEMO=1. Set SEED_DEMO=0 to disable it in development too.
SEED_DEMO=

# Razorpay payment gateway. When BOTH are set, real checkout replaces the
# simulated test-mode payments. Get keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
